# Copy to .env and fill in. docker-compose reads SENTRY_DSN/ENV from here.
# DATABASE_URL is set by docker-compose for the container; override only if you
# run the app outside Docker (then point it at localhost:5432).

# DATABASE_URL=postgresql+asyncpg://wnotes:wnotes@localhost:5432/wnotes

# Paste your Sentry *Python* project DSN here to enable backend error reporting.
# Leave blank and Sentry is a no-op.
SENTRY_DSN=

# development | production — controls Sentry environment tag + sample rates.
ENV=development

# Path (inside the container) to the Firebase service-account JSON used to verify
# ID tokens. Put the file at backend/firebase-service-account.json, then set:
#   FIREBASE_CREDENTIALS=/app/firebase-service-account.json
# Leave blank to disable Firebase auth (only anonymous device keys work).
FIREBASE_CREDENTIALS=

# Browser origins allowed to call the API (CORS) — only the web client needs
# this; native apps don't enforce CORS. Comma-separated, or "*" for any origin
# (safe here: auth is a bearer token, not a cookie). For local web dev with the
# Expo dev server this is typically http://localhost:8081.
CORS_ORIGINS=*
