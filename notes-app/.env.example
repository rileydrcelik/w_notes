# Copy to `.env` and fill in. EXPO_PUBLIC_* vars are inlined into the JS bundle
# at build time, so they're readable in the app (never put secrets here).

# Sentry DSN for the React Native project. Leave blank to disable Sentry.
EXPO_PUBLIC_SENTRY_DSN=

# Base URL of the sync backend, reachable from the device/emulator:
#   - Android emulator -> http://10.0.2.2:8000
#   - Physical device  -> http://<your-computer-LAN-IP>:8000
#   - iOS simulator    -> http://localhost:8000
# Leave blank to run offline-only (sync no-ops).
EXPO_PUBLIC_API_URL=

# --- Firebase Auth (from Firebase console → Project settings → your Web app) ---
# Leave blank to keep the app anonymous (no sign-in; device-key sync only).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# OAuth *web* client ID (Authentication → Sign-in method → Google → Web SDK
# configuration). Required for Google sign-in on the device.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
