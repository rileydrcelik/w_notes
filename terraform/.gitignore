# Never commit state (may contain secrets) or local provider binaries.
# (.terraform.lock.hcl is intentionally NOT ignored — commit it to pin providers.)
*.tfstate
*.tfstate.*
.terraform/

# Real values (secrets) — only the .example templates are tracked.
terraform.tfvars
*.auto.tfvars
backend.hcl

# Saved plan files are zip archives embedding the full resolved state
# (every secret in plaintext). Never commit them. This gap leaked the
# Firebase/RDS/Cloudflare secrets via terraform/tfplan{,2}.
tfplan
tfplan*
*.tfplan
